# RetailCRM API credentials
RETAILCRM_URL=https://your-domain.retailcrm.ru
RETAILCRM_API_KEY=your_api_key_here

# Site code configured in RetailCRM (used for order creation)
RETAILCRM_SITE=your_site_code

# Supabase credentials (Settings → API in your Supabase project)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=your_secret_key_here

# Telegram bot (from @BotFather)
# On Render: set these in the Environment section, not in .env
TG_BOT_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here
WEBHOOK_SECRET=your_webhook_secret_here
